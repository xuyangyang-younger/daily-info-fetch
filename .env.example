# Daily News Digest — 环境变量示例
# 部署时复制为 .env 并填入真实值；切勿把此文件里的真实 token 提交 git。

# ── Hermes LLM 后端 ────────────────────────────────────
HERMES_API_URL=http://localhost:8000/v1/chat/completions
HERMES_API_KEY=CHANGE_ME

# ── 微信 iLink Bot ─────────────────────────────────────
# 形如 xxx@im.bot:xxxxxx
WEIXIN_TOKEN=CHANGE_ME@im.bot:CHANGE_ME
# 目标用户或群，形如 xxx@im.wechat
WEIXIN_CHAT_ID=CHANGE_ME@im.wechat
# Bot 账号 ID，形如 xxx@im.bot
WEIXIN_ACCOUNT_ID=CHANGE_ME@im.bot

# ── 可选：路径/超时覆盖 ────────────────────────────────
# HERMES_AGENT_PATH=/root/.hermes/hermes-agent
# DAILY_NEWS_LOG_DIR=~/daily-news-digest/logs
# DAILY_NEWS_STATE_DIR=~/daily-news-digest/state
# DAILY_NEWS_FETCH_TIMEOUT=10
# DAILY_NEWS_FETCH_BUDGET=20
